[colors]
background = #222222
background-alt = #222222
foreground = #FFFFFF
foreground-alt = #FFFFFF
primary = #FFFFFF
secondary = #e60053
alert = #333

[bar/main]
monitor = ${env:MONITOR:}
width = 100%
height = 32

font-0 = Terminus (TTF):size=12;0
font-1 = HackNerdFontMono:size=11;2

background = #111111
foreground = ${colors.foreground}

line-size = 3
line-color = #000000

border-top-size = 10
border-left-size = 14
border-right-size = 14
border-bottom-size = 0
border-color = #00000000

padding-left = 1
padding-right = 2

module-margin-left = 0
module-margin-right = 3

modules-left = i3
modules-center = date
modules-right = pulseaudio cpu memory mail checkupdate network-wired network-wireless power

cursor-click = pointer
cursor-scroll = ns-resize

wm-restack = bspwm

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; workspace icons
ws-icon-active-font = 1
ws-icon-0 = 1;ÔČ®
ws-icon-1 = 2;ÔĀĽ
ws-icon-2 = 3;ÔĄ°
ws-icon-3 = 4;ÔĎ≥
ws-icon-4 = 5;ÔČ¨
ws-icon-5 = 6;ÔČ¨
ws-icon-6 = 7;ÔČ¨
ws-icon-7 = 8;ÔĄõ
ws-icon-8 = 9;ÔāÜ
ws-icon-9 = 10;ÔĄ†
ws-icon-default = ÔČ¨

; focused = Active workspace on focused monitor
label-focused = %icon%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = %icon%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %icon%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %icon%
label-urgent-background = ${colors.alert}
label-urgent-padding = 3

; Separator in between workspaces
; label-separator = |


[module/mail]
type = custom/script
format-prefix = "ÔÉ† "
exec = ruby ~/.config/polybar/modules/mail.rb
tail = true
label = %output%
;format-underline = #57F2AA
click-left = brave webmail.magnan.one

[module/checkupdate]
type = custom/script
format-prefix = "ÔÄô "
exec = checkupdates+aur | wc -l
tail = true
label = %output%
;format-underline = #FFFFFF
click-left = alacritty -e yay -Syyu
interval=120

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÔáÄ  "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = #ff6600
label = %percentage_used%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "Ôčõ  "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = #FDEE00
label = %percentage%%

[module/network-wired]
type = internal/network
interface = enp0s31f6
interval = 3.0

label-connected = Connexion filaire [%local_ip%]
label-connected-foreground = #eefafafa
;label-disconnected = Aucune connexion
label-disconnected-foreground = #66ffffff
;format-connected-underline = #B16761

format-connected = %{A1:$HOME/.config/polybar/modules/rofi-netctl.sh:}<ramp-signal><label-connected>%{A} 
;format-disconnected = %{A1:$HOME/.config/polybar/modules/rofi-netctl.sh:}<label-disconnected>%{A}
ramp-signal-foreground = ${colors.foreground-alt}
; Worst
ramp-signal-0 = "ÔõŅ "
ramp-signal-1 = "ÔõŅ "
ramp-signal-2 = "ÔõŅ "
ramp-signal-3 = "ÔõŅ "
ramp-signal-4 = "ÔõŅ "
; Best
ramp-signal-5 = "ÔõŅ "

[module/network-wireless]
type = internal/network
interface = wlp3s0
interval = 3.0

label-connected = %essid% [%local_ip%]
label-connected-foreground = #eefafafa
;label-disconnected = Aucune connexion
label-disconnected-foreground = #66ffffff
;format-connected-underline = #B16761

format-connected = %{A1:$HOME/.config/polybar/modules/rofi-netctl.sh:}<ramp-signal> <label-connected>%{A} 
;format-disconnected = %{A1:$HOME/.config/polybar/modules/rofi-netctl.sh:}<label-disconnected>%{A}
ramp-signal-foreground = ${colors.foreground-alt}
; Worst
ramp-signal-0 = "Ôáę "
ramp-signal-1 = "Ôáę "
ramp-signal-2 = "Ôáę "
ramp-signal-3 = "Ôáę "
ramp-signal-4 = "Ôáę "
; Best
ramp-signal-5 = "Ôáę "


[module/date]
type = internal/date
interval = 5

date = 
date-alt = "%d/%m/%Y"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = "ÔÄó "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = #D92B54

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

sink = alsa_output.usb-Astro_Gaming_Astro_MixAmp_Pro-00.analog-stereo

format-volume = <label-volume> <bar-volume>
label-volume = ÔÄ®  %percentage%%
label-volume-foreground = ${root.foreground}

label-muted = ÔÄ¶  Mute
label-muted-foreground = ${colors.foreground-alt}

bar-volume-width = 5
bar-volume-foreground-0 = #0b8e81
bar-volume-foreground-1 = #0b8e81
bar-volume-foreground-2 = #0b8e81
bar-volume-foreground-3 = #0b8e81
bar-volume-foreground-4 = #0b8e81
bar-volume-foreground-5 = #0b8e81
bar-volume-foreground-6 = #0b8e81
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/power]
type = custom/script
exec = echo " ÔÄĎ "
click-left = exec ~/.config/polybar/modules/power.sh

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

